# 服务配置
HOST=127.0.0.1
PORT=8111
RELOAD=true

# 模型配置（可选，默认使用项目标准路径）
# MODEL_WEIGHTS_PATH=模型训练/训练输出/best_model.pt
# LABEL_MAPPING_PATH=模型训练/处理后数据/label_mapping.json
# TOKENIZER_MODEL_PATH=模型训练/预训练模型/chinese-roberta-wwm-ext

# 资源配置（可选，默认使用项目标准路径）
# LAW_KNOWLEDGE_BASE_PATH=agent/资源/law_knowledge_base.json

# CORS 配置
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
# CORS_CREDENTIALS=false
# CORS_METHODS=["*"]
# CORS_HEADERS=["*"]

# 功能开关
ENABLE_MEMORY_CACHE=true
ENABLE_SECURITY_CHECK=true
